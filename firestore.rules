rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function projectOwner(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['name', 'ownerId', 'createdAt', 'updatedAt'])
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /extractions/{extractionId} {
        allow read: if isSignedIn() && projectOwner(projectId) == request.auth.uid;

        // Only server (Admin SDK) may create extractions; clients toggle action items.
        allow create, delete: if false;

        // Only actionItems may change from the client (toggle completed).
        allow update: if isSignedIn()
          && resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.rawInput == resource.data.rawInput
          && request.resource.data.summary == resource.data.summary
          && request.resource.data.decisions == resource.data.decisions
          && request.resource.data.createdAt == resource.data.createdAt;
      }
    }
  }
}
