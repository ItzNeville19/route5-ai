# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist-electron

# local embedded DB (auto-created; not committed)
/data/*.sqlite
/data/*.sqlite-*
/data/org-commitment-uploads/

# misc
.DS_Store
*.pem

# local asset renders / exports (large binaries — not tracked)
/ad-output/

# Desktop installers — copy from dist-electron after `npm run electron:dist`, or use NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL to a CDN URL
/public/installers/*.dmg
/public/installers/*.zip
!/public/installers/.gitkeep

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
