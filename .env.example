# Clerk (required for workspace)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Optional — shown on /download as “Direct download” (e.g. GitHub Release .dmg URL).
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=

# Grant full Enterprise-tier limits to specific sign-in emails (comma-separated).
# Example: ROUTE5_ULTIMATE_EMAILS=you@company.com
ROUTE5_ULTIMATE_EMAILS=

# Same as ULTIMATE_EMAILS but by Clerk user id (best for founder accounts — copy from Clerk dashboard).
# Example: ROUTE5_ULTIMATE_USER_IDS=user_2abc123
ROUTE5_ULTIMATE_USER_IDS=

# Fine-grained tiers: email:tier,email2:tier — tier is free | pro | ultra | enterprise
# ROUTE5_ENTITLEMENTS=ops@acme.com:pro,admin@acme.com:enterprise

# Local `npm run dev` only — all signed-in users get Enterprise (max tier). Do not set in production.
# ROUTE5_DEV_MAX_TIER=1

# Commercial packaging: set to 1 in production when you are selling plans (CTAs, messaging).
# Card checkout is separate — paid tiers may still use Contact until Stripe is wired.
# NEXT_PUBLIC_BILLING_LIVE=0

# Slack — OAuth, Events API, slash commands, interactions (see README “Slack app setup”).
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=
# SLACK_WEBHOOK_URL=
# SLACK_ESCALATION_CHANNEL_ID=
# SLACK_STATE_SECRET=
# Encrypt tokens at rest in org_integrations (64 hex chars = 32 bytes). Falls back to SLACK_SIGNING_SECRET hash if unset.
# INTEGRATIONS_ENCRYPTION_KEY=

# Notion — public OAuth integration (see README “Notion integration”).
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# Optional overrides:
# NOTION_API_VERSION=2022-06-28
# NOTION_OAUTH_STATE_SECRET=

# Google — Gmail OAuth + Pub/Sub push (see README “Gmail + Google Cloud setup”).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Full topic name: projects/<project-id>/topics/<topic-name>
# GOOGLE_PUBSUB_TOPIC=
# Shared secret: Pub/Sub push must send Authorization: Bearer <token> (or ?token= for testing).
# GOOGLE_PUBSUB_VERIFICATION_TOKEN=
# Optional — extra recipients for Monday executive summary email (comma-separated).
# ROUTE5_EXECUTIVE_EMAILS=

# OpenAI — Slack/Gmail decision detection and weekly executive HTML email.
# OPENAI_API_KEY=

# Escalation emails (Resend — https://resend.com). Server-only; never expose to the client.
# RESEND_API_KEY=
# RESEND_FROM=Route5 <onboarding@resend.dev>
# ESCALATION_NOTIFY_TO=ops@yourcompany.com

# Supabase (optional) — anon key is used only for Realtime broadcast on /workspace/commitments (same project as NEXT_PUBLIC_SUPABASE_URL).
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vercel Cron: protect GET /api/cron/org-commitment-status in production.
# CRON_SECRET=

# Figma REST import (Integrations → Figma). Personal access token with read access to target files.
# FIGMA_ACCESS_TOKEN=
