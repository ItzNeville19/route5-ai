# Copy to .env.local in the project root, then fill values. .env.local is gitignored.
# Quick copy: cp .env.example .env.local
# See LOCAL_ENV.txt for paths and which Supabase key is which.

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/projects
# New accounts can land on guided onboarding (embedded sign-up uses signUpFallbackRedirectUrl in code too).
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Supabase — https://supabase.com/dashboard → Project Settings → API
# Optional: if unset, the app uses an embedded SQLite DB at data/route5.sqlite (auto-created).
# URL: Project URL field
NEXT_PUBLIC_SUPABASE_URL=
# anon public — "anon" / "publishable" key (often starts with sb_publishable_)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# service_role — secret JWT from the same API page (starts with eyJ). Server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Workspace labels (optional)
NEXT_PUBLIC_WORKSPACE_TIER_PRIMARY=Pro
NEXT_PUBLIC_WORKSPACE_TIER_SECONDARY=Ultra

# OpenAI — https://platform.openai.com/api-keys (server only; never NEXT_PUBLIC_)
# If unset, extractions use the built-in heuristic path (no OpenAI calls).
OPENAI_API_KEY=
OPENAI_MODEL=

# Linear — https://linear.app/settings/account → API → Personal API keys (server only)
LINEAR_API_KEY=

# GitHub — https://github.com/settings/tokens — PAT with issues read on repos you use (server only)
GITHUB_TOKEN=
